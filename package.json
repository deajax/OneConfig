{
  "name": "one-config",
  "version": "0.1.0",
  "description": "OneConfig – AI 工具配置管理桌面应用",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@formily/antdv": "^2.0.1-beta.3",
    "@formily/core": "^2.3.7",
    "@formily/vue": "^2.3.7",
    "@monaco-editor/loader": "^1.7.0",
    "@remixicon/vue": "^4.9.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "ant-design-vue": "^4.2.6",
    "fs-extra": "^11.3.4",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "pinia": "^2.3.1",
    "sudo-prompt": "^9.2.1",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@vitejs/plugin-vue": "^5.2.3",
    "electron": "^33.4.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "less": "^4.2.2",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.8.3",
    "unplugin-auto-import": "^19.1.2",
    "unplugin-vue-components": "^28.5.0",
    "vite": "^5.4.19",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.10"
  },
  "build": {
    "appId": "com.oneconfig.app",
    "productName": "OneConfig",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
