{
  "schema": {
    "type": "object",
    "properties": {
      "api_key": {
        "type": "string",
        "title": "API Key",
        "x-component": "Input",
        "x-component-props": { "type": "password", "placeholder": "sk-..." }
      },
      "base_url": {
        "type": "string",
        "title": "API Base URL",
        "x-component": "Input",
        "x-component-props": { "placeholder": "https://api.openai.com/v1" }
      },
      "model": {
        "type": "string",
        "title": "模型",
        "x-component": "Select",
        "x-component-props": {
          "options": [
            { "label": "gpt-4.1", "value": "gpt-4.1" },
            { "label": "gpt-4.1-mini", "value": "gpt-4.1-mini" },
            { "label": "gpt-4o", "value": "gpt-4o" },
            { "label": "o4-mini", "value": "o4-mini" }
          ]
        }
      },
      "max_tokens": {
        "type": "number",
        "title": "最大 Token 数",
        "x-component": "NumberPicker",
        "x-component-props": { "min": 256, "max": 128000, "step": 256 }
      },
      "temperature": {
        "type": "number",
        "title": "Temperature",
        "x-component": "NumberPicker",
        "x-component-props": { "min": 0, "max": 2, "step": 0.1, "precision": 1 }
      },
      "stream": {
        "type": "boolean",
        "title": "流式输出",
        "x-component": "Switch"
      }
    }
  },
  "defaults": {
    "api_key": "",
    "base_url": "https://api.openai.com/v1",
    "model": "gpt-4.1",
    "max_tokens": 8192,
    "temperature": 0.7,
    "stream": true
  }
}
