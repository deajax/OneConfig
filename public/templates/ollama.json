{
  "schema": {
    "type": "object",
    "properties": {
      "base_url": {
        "type": "string",
        "title": "API 地址",
        "x-component": "Input",
        "x-component-props": { "placeholder": "http://localhost:11434" }
      },
      "model": {
        "type": "string",
        "title": "模型名称",
        "x-component": "Input",
        "x-component-props": { "placeholder": "llama3.2, qwen2.5, mistral..." }
      },
      "num_ctx": {
        "type": "number",
        "title": "上下文长度",
        "x-component": "NumberPicker",
        "x-component-props": { "min": 512, "max": 131072, "step": 512 }
      },
      "temperature": {
        "type": "number",
        "title": "Temperature",
        "x-component": "NumberPicker",
        "x-component-props": { "min": 0, "max": 2, "step": 0.1, "precision": 1 }
      },
      "stream": {
        "type": "boolean",
        "title": "流式输出",
        "x-component": "Switch"
      }
    }
  },
  "defaults": {
    "base_url": "http://localhost:11434",
    "model": "llama3.2",
    "num_ctx": 4096,
    "temperature": 0.8,
    "stream": true
  }
}
